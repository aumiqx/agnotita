# Agnotita — Environment Variables
# Copy to .env and fill in your keys.

# ─── Scraper ──────────────────────────────────────────────────────────────────
# At least one of SERPAPI_KEY or OUTSCRAPER_KEY is required for scraping.

# SerpAPI — Google Maps search (serpapi.com)
SERPAPI_KEY=

# Outscraper — alternative Google Maps API (outscraper.com)
OUTSCRAPER_KEY=

# Apify — Instagram, TripAdvisor scrapers (apify.com)
APIFY_TOKEN=

# ─── Generator ────────────────────────────────────────────────────────────────

# Anthropic — Claude API for content generation (anthropic.com)
# Optional: without this, placeholder content is used.
ANTHROPIC_API_KEY=

# ─── Pipeline ─────────────────────────────────────────────────────────────────

# FTP credentials for Hostinger deployment
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_BASE_DIR=/public_html

# Base domain for subdomains
BASE_DOMAIN=agnotita.com

# Hostinger hPanel API (optional — for subdomain creation)
HOSTINGER_API_KEY=

# cPanel API (fallback for subdomain creation)
CPANEL_URL=
CPANEL_USER=
CPANEL_TOKEN=
